{
  "manifest_version": 3,
  "name": "eCash KZ Extension",
  "version": "1.1.0",
  "description": "eCash KZ расширение для автозаполнения форм",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://websfm.kz/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://websfm.kz/*"
      ],
      "js": [
        "content.js",
        "payload/autofill_runtime.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "eCash KZ Extension",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}